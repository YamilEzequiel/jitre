 # =============================================================================
  # Jitre — Environment Variables
  # -----------------------------------------------------------------------------
  # Copy this file to `.env` and adjust values. Defaults are tuned for local
  # development with `docker compose up -d` (Postgres + Redis).
  # Never commit `.env` to git.
  # =============================================================================


  # -----------------------------------------------------------------------------
  # App / Server
  # -----------------------------------------------------------------------------
  NODE_ENV=development
  PORT=3000
  API_PREFIX=api
  API_VERSION=1

  # Comma-separated list of allowed origins for CORS
  CORS_ORIGINS=http://localhost:4200

  # Rate limiting (per IP)
  THROTTLER_TTL=60
  THROTTLER_LIMIT=120

  # Logging
  LOG_LEVEL=debug
  LOG_PRETTY=true


  # -----------------------------------------------------------------------------
  # Database — PostgreSQL 16
  # -----------------------------------------------------------------------------
  POSTGRES_HOST=localhost
  POSTGRES_PORT=5432
  POSTGRES_USER=jitre
  POSTGRES_PASSWORD=jitre_dev
  POSTGRES_DB=jitre

  # TypeORM
  DATABASE_LOGGING=false
  # NEVER enable synchronize in production — destroys data. Use migrations.
  DATABASE_SYNCHRONIZE=false


  # -----------------------------------------------------------------------------
  # Redis 7 — cache, BullMQ queues, Socket.IO adapter
  # -----------------------------------------------------------------------------
  REDIS_HOST=localhost
  REDIS_PORT=6379
  # Leave empty for local docker compose; set when using managed Redis
  REDIS_PASSWORD=


  # -----------------------------------------------------------------------------
  # Auth — JWT + Argon2
  # -----------------------------------------------------------------------------
  # CHANGE THESE in production. Use `openssl rand -base64 64` to generate.
  JWT_ACCESS_SECRET=dev_access_secret_change_me_change_me
  JWT_ACCESS_TTL=15m
  JWT_REFRESH_SECRET=dev_refresh_secret_change_me_change_me
  JWT_REFRESH_TTL=7d

  # Argon2id parameters for password hashing
  ARGON2_MEMORY_COST=65536
  ARGON2_TIME_COST=3
  ARGON2_PARALLELISM=4


  # -----------------------------------------------------------------------------
  # AI provider (currently Gemini 2.0 Flash; provider-agnostic by design)
  # -----------------------------------------------------------------------------
  AI_PROVIDER=gemini
  GEMINI_API_KEY=
  GEMINI_MODEL=gemini-2.0-flash

  # Budget guard (in USD per month). Soft cap, used for analytics.
  AI_MONTHLY_BUDGET_USD=50

  # Quota guards
  AI_MAX_REQUESTS_PER_DAY=1000
  AI_MAX_REQUESTS_PER_USER_PER_DAY=100
  AI_ADMIN_BYPASS_USER_CAP=true


  # -----------------------------------------------------------------------------
  # Realtime — Socket.IO
  # -----------------------------------------------------------------------------
  WS_PATH=/ws
  WS_MAX_EVENTS_PER_SOCKET_SEC=50
  WS_MAX_ROOMS_PER_SOCKET=200

  # Pub/sub channel prefix for Socket.IO Redis adapter (multi-instance setups)
  SOCKETIO_REDIS_CHANNEL_PREFIX=socketio


  # -----------------------------------------------------------------------------
  # Storage — attachments
  # -----------------------------------------------------------------------------
  # Driver: `local` (filesystem) or `s3` (AWS S3 / Cloudflare R2 / MinIO)
  STORAGE_DRIVER=local
  STORAGE_LOCAL_ROOT=./uploads
  STORAGE_MAX_FILE_SIZE_MB=25
  STORAGE_PUBLIC_BASE_URL=http://localhost:3000

  # Secret for signing presigned URLs on the `local` driver.
  # REQUIRED in production. Falls back to JWT_ACCESS_SECRET if unset.
  STORAGE_LOCAL_SIGNING_SECRET=

  # S3 / R2 (only required when STORAGE_DRIVER=s3)
  AWS_REGION=
  AWS_ACCESS_KEY_ID=
  AWS_SECRET_ACCESS_KEY=
  STORAGE_S3_BUCKET=
  # Cloudflare R2 / MinIO custom endpoint (leave empty for AWS S3)
  R2_ENDPOINT=


  # -----------------------------------------------------------------------------
  # Email — SMTP (opcional; menciones y notificaciones)
  # -----------------------------------------------------------------------------
  SMTP_HOST=
  SMTP_PORT=587
  SMTP_USER=
  SMTP_PASS=
  SMTP_SECURE=false
  EMAIL_FROM=Jitre <no-reply@jitre.local>


  # -----------------------------------------------------------------------------
  # Search
  # -----------------------------------------------------------------------------
  # `pg` (Postgres full-text search) — funciona out of the box.
  # Future: `meilisearch`, `typesense`, `elasticsearch`.
  SEARCH_ENGINE=pg


  # -----------------------------------------------------------------------------
  # Background jobs — BullMQ
  # -----------------------------------------------------------------------------
  # Habilita el Bull Board UI en /admin/queues (solo dev/staging)
  ENABLE_BULL_BOARD=false