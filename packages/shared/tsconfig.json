{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "composite": true,
    "declarationMap": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
