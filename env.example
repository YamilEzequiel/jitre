# ============================================================
#  Jitre — environment variables
# ============================================================
# Copy this file to `.env` and adjust as needed:
#
#   cp env.example .env
#
# Defaults work out-of-the-box for local development with the
# bundled docker-compose.yml (Postgres + Redis).

# ------------------------------------------------------------
# Runtime
# ------------------------------------------------------------
NODE_ENV=development

# Backend HTTP server
PORT=3000
API_PREFIX=api
API_VERSION=1
CORS_ORIGINS=http://localhost:4200

# Frontend dev server port (only used by ng serve)
FRONTEND_PORT=4200

# ------------------------------------------------------------
# Postgres
# ------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=jitre
POSTGRES_PASSWORD=jitre_dev
POSTGRES_DB=jitre
DATABASE_LOGGING=false
# Never enable in production — TypeORM will rewrite your schema on boot.
DATABASE_SYNCHRONIZE=false

# ------------------------------------------------------------
# Redis (cache + BullMQ jobs + Socket.IO adapter)
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ------------------------------------------------------------
# Auth — JWT + Argon2id
# ------------------------------------------------------------
# REPLACE BOTH SECRETS BEFORE DEPLOYING. The defaults are public.
JWT_ACCESS_SECRET=dev_access_secret_change_me_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Argon2id cost — increase for production. These defaults take ~150ms on
# a 2020 laptop, which is the recommended floor.
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ------------------------------------------------------------
# File storage
# ------------------------------------------------------------
# Drivers: local | s3 | r2 | minio
# 'local' writes to STORAGE_LOCAL_ROOT (great for dev, NOT for prod).
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./uploads
STORAGE_MAX_FILE_SIZE_MB=25
STORAGE_PUBLIC_BASE_URL=http://localhost:3000/api/v1/files
# Used to sign URLs for local storage. Leave empty in dev.
STORAGE_LOCAL_SIGNING_SECRET=

# S3 / Cloudflare R2 / MinIO — fill these when STORAGE_DRIVER != 'local'
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
STORAGE_S3_BUCKET=
R2_ENDPOINT=

# ------------------------------------------------------------
# AI
# ------------------------------------------------------------
# Providers: GEMINI (default) | ANTHROPIC | OPENAI
AI_PROVIDER=GEMINI

# Get a Gemini key at https://aistudio.google.com/apikey
# Leave empty to disable AI features entirely.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Cost guardrails per workspace
AI_MONTHLY_BUDGET_USD=50
AI_MAX_REQUESTS_PER_DAY=1000
AI_MAX_REQUESTS_PER_USER_PER_DAY=100
AI_ADMIN_BYPASS_USER_CAP=true

# ------------------------------------------------------------
# Realtime (Socket.IO)
# ------------------------------------------------------------
WS_PATH=/ws
WS_MAX_EVENTS_PER_SOCKET_SEC=50
WS_MAX_ROOMS_PER_SOCKET=100
SOCKETIO_REDIS_CHANNEL_PREFIX=socketio

# ------------------------------------------------------------
# Observability
# ------------------------------------------------------------
# Levels: fatal | error | warn | info | debug | trace
LOG_LEVEL=debug
# Pretty-print logs in dev; set to false in prod for structured JSON.
LOG_PRETTY=true

# ------------------------------------------------------------
# Throttler (global request rate limit)
# ------------------------------------------------------------
THROTTLER_TTL=60
THROTTLER_LIMIT=120

# ------------------------------------------------------------
# Analytics / Search / Jobs
# ------------------------------------------------------------
ANALYTICS_MAX_DATE_RANGE_DAYS=365
SEARCH_ENGINE=pg
BULLMQ_PREFIX=jitre
JOB_LOG_RETENTION_DAYS=90
ENABLE_BULL_BOARD=false

# ------------------------------------------------------------
# Demo mode
# ------------------------------------------------------------
# When true, the login page surfaces the seed credentials
# (admin@jitre.dev / admin) so a tester can sign in immediately.
DEMO_MODE=false
